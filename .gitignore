# Database - DO NOT IGNORE! The database MUST be committed to git
# so user customizations survive container rebuilds.
# Only ignore WAL/SHM temp files (they're recreated automatically)
db/*.db-wal
db/*.db-shm
db/custom-seed-backup.db

# Upload directory (regenerated, too large for git)
upload/

# Keep the backup directory with JSON export and restore script
# but exclude large .db files
backup/*.db

# Large media files - stored separately
public/videos/
public/uploads/*.mp4

# Upload directory (user/bot content - regenerated by auto-poster)
public/uploads/

# Old git backup
git-old-backup/
.git-old-backup/

# Download directory (screenshots, not needed in repo)
download/

# Agent context files
agent-ctx/

