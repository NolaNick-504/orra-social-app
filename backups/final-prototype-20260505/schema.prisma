// ORRA Social Media Platform - Multi-User Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE USER MODEL
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  handle        String   @unique
  password      String   // hashed
  avatar        String   @default("/api/uploads?path=images/orra-logo.png")
  coverImage    String   @default("/api/uploads?path=images/profile-cover.png")
  bio           String   @default("")
  location      String   @default("")
  website       String   @default("")
  verified      Boolean  @default(false)
  online        Boolean  @default(false)
  lastSeen      DateTime @default(now())

  // Aura Sphere
  auraTokens    Int      @default(100)
  auraLevel     Int      @default(1)
  auraXP        Int      @default(50)
  dailyStreak   Int      @default(0)
  lastActiveDate String  @default("")

  // Badges (stored as JSON string array)
  badges        String   @default("[]")

  // Profile setup tracking
  profileSetupComplete Boolean @default(false)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  follows       Follow[]         @relation("UserFollows")
  followers     Follow[]         @relation("UserFollowers")
  sentMessages  DirectMessage[]
  chatMembers   ChatMember[]
  notifications Notification[]   @relation("UserNotifications")
  triggeredNotifs Notification[] @relation("UserTriggeredNotifications")
  stories       Story[]
  reels         Reel[]
  danceEntries  DanceEntry[]
  hubMembers    HubMember[]
  hubPosts      HubPost[]
  reposts       Repost[]
  saves         Save[]
  tokenActions  TokenAction[]
  sharedPosts   SharedPost[]
  pollVotes     PollVote[]

  // NextAuth
  accounts      Account[]
  sessions      Session[]
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// POSTS (Pulse)
// ============================================

model Post {
  id          String   @id @default(cuid())
  text        String
  images      String   @default("[]")  // JSON array of image URLs
  vibeTag     String   @default("hyped")
  type        String   @default("text") // text, image
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  sharesCount Int      @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  comments    Comment[]
  postLikes   Like[]        @relation("PostLikes")
  reposts     Repost[]
  postSaves   Save[]        @relation("PostSaves")
  sharedPosts SharedPost[]
  poll        Poll?

  @@index([authorId])
  @@index([vibeTag])
  @@index([createdAt])
}

// ============================================
// COMMENTS
// ============================================

model Comment {
  id        String   @id @default(cuid())
  text      String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([authorId])
}

// ============================================
// LIKES (Unified for posts, reels, dance entries, hub posts)
// ============================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId  String   // ID of the liked item
  targetType String  // "post", "reel", "danceEntry", "hubPost", "comment"

  // Optional relations for type-safe access
  post      Post?    @relation("PostLikes", fields: [targetId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, targetId, targetType])
  @@index([targetId, targetType])
  @@index([userId])
}

// ============================================
// FOLLOWS
// ============================================

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================
// STORIES
// ============================================

model Story {
  id        String   @id @default(cuid())
  image     String
  viewed    Boolean  @default(false)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime // Stories expire after 24h

  @@index([authorId])
}

// ============================================
// REELS (Prism)
// ============================================

model Reel {
  id          String   @id @default(cuid())
  title       String
  thumbnail   String
  videoUrl    String   @default("")
  views       Int      @default(0)
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  category    String   @default("Trending")
  song        String   @default("")
  isRemix     Boolean  @default(false)
  isLive      Boolean  @default(false)

  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([creatorId])
  @@index([category])
}

// ============================================
// DANCE CHALLENGE
// ============================================

model DanceChallenge {
  id            String   @id @default(cuid())
  name          String
  hashtag       String
  song          String
  description   String
  prize         String
  secondPrize   String
  thirdPrize    String
  bannerImage   String   @default("")
  timeRemaining Int      @default(259200) // 72 hours in seconds
  active        Boolean  @default(true)

  entries       DanceEntry[]
  createdAt     DateTime @default(now())
}

model DanceEntry {
  id          String   @id @default(cuid())
  description String
  thumbnail   String   @default("")
  likesCount  Int      @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   DanceChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([challengeId])
  @@index([authorId])
}

// ============================================
// HUBS
// ============================================

model Hub {
  id          String   @id @default(cuid())
  name        String
  icon        String
  cover       String   @default("")
  description String
  membersCount Int     @default(0)
  onlineCount Int      @default(0)

  members     HubMember[]
  posts       HubPost[]

  createdAt   DateTime @default(now())
}

model HubMember {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubId    String
  hub      Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, hubId])
}

model HubPost {
  id          String   @id @default(cuid())
  text        String
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  hubId       String
  hub         Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([hubId])
}

// ============================================
// REPOSTS (Echo)
// ============================================

model Repost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

// ============================================
// SAVES (Bookmarks)
// ============================================

model Save {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId  String
  targetType String  @default("post") // "post", "reel"

  // Optional relations
  post      Post?    @relation("PostSaves", fields: [targetId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, targetId, targetType])
}

// ============================================
// DIRECT MESSAGES / CHAT
// ============================================

model Chat {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   ChatMember[]
  messages  DirectMessage[]
}

model ChatMember {
  id       String   @id @default(cuid())
  chatId   String
  chat     Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  unreadCount Int    @default(0)

  @@unique([chatId, userId])
  @@index([userId])
}

model DirectMessage {
  id        String   @id @default(cuid())
  text      String
  imageUrl  String   @default("")
  reaction  String   @default("")

  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id         String   @id @default(cuid())
  action     String
  type       String   // like, follow, comment, share, mention, remix, feature, token, levelup, challenge, hub
  read       Boolean  @default(false)
  thumbnail  String   @default("")

  userId     String
  user       User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  triggeredByUserId String?
  triggeredByUser   User?    @relation("UserTriggeredNotifications", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([userId])
}

// ============================================
// TOKEN ACTIONS (Anti-farming tracking)
// ============================================

model TokenAction {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // "like_post", "like_reel", "follow", "repost", "share_dm", "comment", "post", "chat", "daily_streak", "hub_join", "dance_entry", "dance_vote", "reel_view"
  targetId   String   // ID of the target item
  tokensEarned Int
  xpEarned   Int

  createdAt  DateTime @default(now())

  @@unique([userId, action, targetId])
  @@index([userId])
}

// ============================================
// POLLS
// ============================================

model Poll {
  id          String   @id @default(cuid())
  question    String
  postId      String   @unique
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  duration    Int      @default(86400) // 24 hours in seconds
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  options     PollOption[]

  @@index([postId])
}

model PollOption {
  id        String   @id @default(cuid())
  text      String
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes     PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, optionId])
  @@index([userId])
  @@index([optionId])
}

// ============================================
// SHARED POSTS (via DM)
// ============================================

model SharedPost {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId    String   // which chat it was shared to

  createdAt DateTime @default(now())

  @@index([userId])
}
