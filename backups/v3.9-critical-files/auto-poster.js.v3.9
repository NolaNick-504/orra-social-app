const VIBES = ['hyped', 'laughing', 'chill', 'dramatic', 'focused', 'peaceful', 'news', 'sports'];
function pick(a) { return a[Math.floor(Math.random() * a.length)]; }

// Use Prisma directly via npx
function prismaQuery(query) {
  try {
    const result = execSync(
      `cd ${PROJECT_DIR} && npx prisma db execute --stdin <<< "${query.replace(/"/g, '\\"')}" 2>/dev/null`,
      { timeout: 15000, encoding: 'utf-8' }
    );
    return result;
  } catch (e) {
    return null;
  }
}

// Better: use the Prisma Client directly via a Node script
function createPostDirectly(authorId, text, vibeTag) {
  try {
    const script = `
const { PrismaClient } = require('@prisma/client');
const db = new PrismaClient();
async function run() {
  try {
    const post = await db.post.create({
      data: { text: ${JSON.stringify(text)}, vibeTag: ${JSON.stringify(vibeTag)}, type: 'text', authorId: ${JSON.stringify(authorId)}, likesCount: 0, commentsCount: 0, sharesCount: 0 }
    });
    await db.user.update({ where: { id: ${JSON.stringify(authorId)} }, data: { auraTokens: { increment: 5 }, auraXP: { increment: 10 } } });
    console.log(JSON.stringify({ success: true, id: post.id }));
  } catch(e) { console.log(JSON.stringify({ success: false, error: e.message })); }
  finally { await db.\$disconnect(); }
}
run();
`;
    const result = execSync(`cd ${PROJECT_DIR} && node -e '${script.replace(/'/g, "'\"'\"'")}'`, {
      timeout: 15000, encoding: 'utf-8'
    });
    return JSON.parse(result.trim().split('\n').pop());
  } catch (e) {
    return { success: false, error: e.message };
  }
}

// Load user IDs
let userIds = [];
function loadUsers() {
  try {
    const script = `
const { PrismaClient } = require('@prisma/client');
const db = new PrismaClient();
async function run() {
  const users = await db.user.findMany({ where: { handle: { not: '@nickorraceo' } }, select: { id: true } });
  console.log(JSON.stringify(users.map(u => u.id)));
  await db.\$disconnect();
}
run();
`;
    const result = execSync(`cd ${PROJECT_DIR} && node -e '${script.replace(/'/g, "'\"'\"'")}'`, {
      timeout: 10000, encoding: 'utf-8'
    });
    userIds = JSON.parse(result.trim().split('\n').pop());
    return userIds.length;
  } catch {
    return 0;
  }
}

function postOnce() {
  try {
    if (userIds.length === 0) {
      const count = loadUsers();
      if (count === 0) { console.error('[AutoPoster] No users'); return; }
    }
    const count = Math.floor(Math.random() * 3) + 1;
    for (let i = 0; i < count; i++) {
      const authorId = pick(userIds);
      const cats = Object.keys(POSTS);
      const text = pick(POSTS[pick(cats)]);
      const vibeTag = pick(VIBES);
      const result = createPostDirectly(authorId, text, vibeTag);
      if (result.success) {
        console.log(`[AutoPoster] ✅ "${text.substring(0, 50)}..."`);
      } else {
        console.warn('[AutoPoster] ⚠️ Failed:', result.error?.substring(0, 80));
      }
    }
  } catch (e) { console.error('[AutoPoster] Error:', e.message); }
}

// Main
console.log('[AutoPoster] 🤖 Starting...');
const userCount = loadUsers();
console.log(`[AutoPoster] ${userCount} users loaded`);
if (userCount > 0) {
  postOnce();
  setInterval(postOnce, 5 * 60 * 1000);
  console.log('[AutoPoster] ⏰ Posting every 5 minutes');
} else {
  console.error('[AutoPoster] No users found, exiting');
}
