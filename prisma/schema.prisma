// ORRA Social Media Platform - Multi-User Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE USER MODEL
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  handle        String   @unique
  password      String   // hashed
  avatar        String   @default("/api/uploads?path=images/orra-logo.png")
  coverImage    String   @default("/api/uploads?path=images/profile-cover.png")
  bio           String   @default("")
  location      String   @default("")
  website       String   @default("")
  verified      Boolean  @default(false)
  online        Boolean  @default(false)
  lastSeen      DateTime @default(now())

  // Aura Sphere
  auraTokens    Int      @default(100)
  auraLevel     Int      @default(1)
  auraXP        Int      @default(50)
  dailyStreak   Int      @default(0)
  lastActiveDate String  @default("")

  // Badges (stored as JSON string array)
  badges        String   @default("[]")

  // Marketplace - Active items
  activeTheme     String   @default("")
  activeNameEffect String  @default("")
  customTitle     String   @default("")

  // Profile setup tracking
  profileSetupComplete Boolean @default(false)

  // Profile Song (MySpace-style background music)
  profileSongUrl    String  @default("")
  profileSongTitle  String  @default("")
  profileSongArtist String  @default("")

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  follows       Follow[]         @relation("UserFollows")
  followers     Follow[]         @relation("UserFollowers")
  sentMessages  DirectMessage[]
  chatMembers   ChatMember[]
  notifications Notification[]   @relation("UserNotifications")
  triggeredNotifs Notification[] @relation("UserTriggeredNotifications")
  stories       Story[]
  reels         Reel[]
  reelComments  ReelComment[]
  danceEntries  DanceEntry[]
  hubMembers    HubMember[]
  hubPosts      HubPost[]
  reposts       Repost[]
  saves         Save[]
  tokenActions  TokenAction[]
  sharedPosts   SharedPost[]
  pollVotes     PollVote[]
  blocks        Block[]         @relation("UserBlocks")
  blockedBy     Block[]         @relation("UserBlocked")
  mutes         Mute[]          @relation("UserMutes")
  mutedBy       Mute[]          @relation("UserMuted")
  reports       Report[]        @relation("UserReports")
  reelHistory   ReelHistory[]
  purchases     Purchase[]

  // Challenge/Game relations
  challengeSessionsWon ChallengeSession[]
  sentChallengeInvites ChallengeInvite[]  @relation("SentChallengeInvites")
  receivedChallengeInvites ChallengeInvite[] @relation("ReceivedChallengeInvites")
  challengeParticipants ChallengeParticipant[]
  gamePlayer1 GameSession[] @relation("GamePlayer1")
  gamePlayer2 GameSession[] @relation("GamePlayer2")
  gameWinner GameSession[] @relation("GameWinner")
  gameVotes GameVote[]
  hotTakes HotTake[]
  hotTakeVotes HotTakeVote[]

  // NextAuth
  accounts      Account[]
  sessions      Session[]
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// POSTS (Pulse)
// ============================================

model Post {
  id          String   @id @default(cuid())
  text        String
  images      String   @default("[]")  // JSON array of image URLs
  vibeTag     String   @default("hyped")
  type        String   @default("text") // text, image
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  sharesCount Int      @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  comments    Comment[]
  reposts     Repost[]
  postSaves   Save[]        @relation("PostSaves")
  sharedPosts SharedPost[]
  poll        Poll?

  @@index([authorId])
  @@index([vibeTag])
  @@index([createdAt])
}

// ============================================
// COMMENTS
// ============================================

model Comment {
  id        String   @id @default(cuid())
  text      String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // If this comment was made on an echo (repost), store the repost ID so comments
  // are separate between the original post and echoed posts
  repostId  String?
  repost    Repost?  @relation(fields: [repostId], references: [id], onDelete: Cascade)

  // Threaded replies: parentId points to the parent comment, replyToName stores
  // the display name of the user being replied to
  parentId    String?
  replyToName String?

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([authorId])
  @@index([repostId])
  @@index([parentId])
}

// ============================================
// LIKES (Unified for posts, reels, dance entries, hub posts)
// ============================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId  String   // ID of the liked item
  targetType String  // "post", "reel", "danceEntry", "hubPost", "comment"
  reactionType String @default("like") // "like", "wow", "omg", "wtf", "laughing", "sad", "care"

  // No foreign key on targetId — it's polymorphic (points to different tables based on targetType)
  // The post relation is handled via application-level joins, not DB-level FK

  createdAt DateTime @default(now())

  @@unique([userId, targetId, targetType])
  @@index([targetId, targetType])
  @@index([userId])
  @@index([targetId, targetType, reactionType])
}

// ============================================
// FOLLOWS
// ============================================

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================
// STORIES
// ============================================

model Story {
  id        String   @id @default(cuid())
  image     String
  viewed    Boolean  @default(false)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime // Stories expire after 24h

  @@index([authorId])
}

// ============================================
// REELS (Prism)
// ============================================

model Reel {
  id          String   @id @default(cuid())
  title       String
  thumbnail   String
  videoUrl    String   @default("")
  views       Int      @default(0)
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  category    String   @default("Trending")
  song        String   @default("")
  isRemix     Boolean  @default(false)
  isLive      Boolean  @default(false)

  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  comments   ReelComment[]
  history    ReelHistory[]

  @@index([creatorId])
  @@index([category])
}

// ============================================
// REEL COMMENTS
// ============================================

model ReelComment {
  id        String   @id @default(cuid())
  text      String
  reelId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([reelId])
  @@index([authorId])
}

// ============================================
// DANCE CHALLENGE
// ============================================

model DanceChallenge {
  id            String   @id @default(cuid())
  name          String
  hashtag       String
  song          String
  description   String
  prize         String
  secondPrize   String
  thirdPrize    String
  bannerImage   String   @default("")
  timeRemaining Int      @default(259200) // 72 hours in seconds
  active        Boolean  @default(true)

  entries       DanceEntry[]
  createdAt     DateTime @default(now())
}

model DanceEntry {
  id          String   @id @default(cuid())
  description String
  thumbnail   String   @default("")
  likesCount  Int      @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   DanceChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([challengeId])
  @@index([authorId])
}

// ============================================
// HUBS
// ============================================

model Hub {
  id          String   @id @default(cuid())
  name        String
  icon        String
  cover       String   @default("")
  description String
  membersCount Int     @default(0)
  onlineCount Int      @default(0)

  members     HubMember[]
  posts       HubPost[]

  createdAt   DateTime @default(now())
}

model HubMember {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubId    String
  hub      Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, hubId])
}

model HubPost {
  id          String   @id @default(cuid())
  text        String
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  hubId       String
  hub         Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([hubId])
}

// ============================================
// REPOSTS (Echo)
// ============================================

model Repost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  comments  Comment[]

  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

// ============================================
// SAVES (Bookmarks)
// ============================================

model Save {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId  String
  targetType String  @default("post") // "post", "reel"

  // Optional relations
  post      Post?    @relation("PostSaves", fields: [targetId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, targetId, targetType])
}

// ============================================
// DIRECT MESSAGES / CHAT
// ============================================

model Chat {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   ChatMember[]
  messages  DirectMessage[]
}

model ChatMember {
  id       String   @id @default(cuid())
  chatId   String
  chat     Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  unreadCount Int    @default(0)

  @@unique([chatId, userId])
  @@index([userId])
}

model DirectMessage {
  id        String   @id @default(cuid())
  text      String
  imageUrl  String   @default("")
  reaction  String   @default("")

  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id         String   @id @default(cuid())
  action     String
  type       String   // like, follow, comment, share, mention, remix, feature, token, levelup, challenge, hub
  read       Boolean  @default(false)
  thumbnail  String   @default("")
  postId     String?  // Links notification to a specific post for click-through navigation

  userId     String
  user       User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  triggeredByUserId String?
  triggeredByUser   User?    @relation("UserTriggeredNotifications", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([userId])
  @@index([postId])
}

// ============================================
// TOKEN ACTIONS (Anti-farming tracking)
// ============================================

model TokenAction {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // "like_post", "like_reel", "follow", "repost", "share_dm", "comment", "post", "chat", "daily_streak", "hub_join", "dance_entry", "dance_vote", "reel_view"
  targetId   String   // ID of the target item
  tokensEarned Int
  xpEarned   Int

  createdAt  DateTime @default(now())

  @@unique([userId, action, targetId])
  @@index([userId])
}

// ============================================
// POLLS
// ============================================

model Poll {
  id          String   @id @default(cuid())
  question    String
  postId      String   @unique
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  duration    Int      @default(86400) // 24 hours in seconds
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  options     PollOption[]

  @@index([postId])
}

model PollOption {
  id        String   @id @default(cuid())
  text      String
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes     PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, optionId])
  @@index([userId])
  @@index([optionId])
}

// ============================================
// SHARED POSTS (via DM)
// ============================================

model SharedPost {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId    String   // which chat it was shared to

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// BLOCKS
// ============================================

model Block {
  id         String   @id @default(cuid())
  blockerId  String
  blocker    User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId  String
  blocked    User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ============================================
// MUTES
// ============================================

model Mute {
  id         String   @id @default(cuid())
  muterId    String
  muter      User     @relation("UserMutes", fields: [muterId], references: [id], onDelete: Cascade)
  mutedId    String
  muted      User     @relation("UserMuted", fields: [mutedId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([muterId, mutedId])
  @@index([muterId])
  @@index([mutedId])
}

// ============================================
// REEL HISTORY (Watch History)
// ============================================

model ReelHistory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reelId         String
  reel           Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  watchProgress  Float    @default(0)   // 0-100 percentage
  watchedAt      DateTime @default(now())

  @@unique([userId, reelId])
  @@index([userId, watchedAt])
  @@index([reelId])
}

// ============================================
// REPORTS
// ============================================

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String   // ID of the reported content
  targetType  String   // "post", "comment", "reel", "user"
  reason      String   // "spam", "harassment", "inappropriate", "other"
  description String   @default("")
  status      String   @default("pending") // "pending", "reviewed", "resolved", "dismissed"

  createdAt   DateTime @default(now())

  @@index([reporterId])
  @@index([targetId, targetType])
  @@index([status])
}

// ============================================
// MARKETPLACE PURCHASES
// ============================================

model Purchase {
  id             String   @id @default(cuid())
  userId         String
  itemId         String
  category       String   // "Themes", "Effects", "Badges", "Boosts", "Titles"
  name           String
  cost           Int
  isActive       Boolean  @default(false)
  selectedOption String   @default("")  // Color/variant choice

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@index([userId, category])
}

// ============================================
// CHALLENGE GAMES
// ============================================

model ChallengeGame {
  id          String   @id @default(cuid())
  type        String   @unique   // roast_battle, hot_take, etc.
  name        String
  description String
  icon        String
  color       String
  tokenCost   Int      @default(0)
  tokenReward Int      @default(0)
  xpReward    Int      @default(0)
  players     Int      @default(2)
  active      Boolean  @default(true)
  playsCount  Int      @default(0)

  sessions    ChallengeSession[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([type])
}

model ChallengeSession {
  id        String   @id @default(cuid())
  gameId    String
  status    String   @default("waiting") // waiting, active, completed, cancelled
  maxPlayers Int     @default(2)

  game      ChallengeGame  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]
  invites   ChallengeInvite[]
  winnerId  String?
  winner    User?          @relation(fields: [winnerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
  @@index([status])
  @@index([winnerId])
}

model ChallengeParticipant {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  score     Int      @default(0)
  joinedAt  DateTime @default(now())

  session   ChallengeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model ChallengeInvite {
  id         String   @id @default(cuid())
  sessionId  String
  senderId   String
  receiverId String
  status     String   @default("pending") // pending, accepted, declined, expired

  session    ChallengeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender     User             @relation("SentChallengeInvites", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ReceivedChallengeInvites", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sessionId])
  @@index([senderId])
  @@index([receiverId, status])
}

// ============================================
// GAMES (HOT TAKE, MATCHMAKING, ETC.)
// ============================================

model GameSession {
  id          String   @id @default(cuid())
  type        String   // hot_take, rate_my_fit, truth_or_dare, etc.
  status      String   @default("active") // active, completed, expired
  player1Id   String
  player2Id   String?
  winnerId    String?
  rounds      GameRound[]
  votes       GameVote[]

  player1     User     @relation("GamePlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2     User?    @relation("GamePlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner      User?    @relation("GameWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
  @@index([type])
}

model GameRound {
  id          String   @id @default(cuid())
  sessionId   String
  roundNumber Int
  prompt      String?
  player1Answer String?
  player2Answer String?
  winnerId    String?

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([sessionId])
}

model GameVote {
  id          String   @id @default(cuid())
  sessionId   String
  voterId     String
  voteFor     String   // player1 or player2
  roundId     String?

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  voter       User        @relation(fields: [voterId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([sessionId, voterId, roundId])
  @@index([sessionId])
  @@index([voterId])
}

model HotTake {
  id          String   @id @default(cuid())
  authorId    String
  text        String
  status      String   @default("active") // active, completed, expired
  wVotes      Int      @default(0)
  lVotes      Int      @default(0)

  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes       HotTakeVote[]

  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([authorId])
  @@index([status])
  @@index([expiresAt])
}

model HotTakeVote {
  id          String   @id @default(cuid())
  takeId      String
  voterId     String
  vote        String   // "W" or "L"

  take        HotTake  @relation(fields: [takeId], references: [id], onDelete: Cascade)
  voter       User     @relation(fields: [voterId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([takeId, voterId])
  @@index([takeId])
  @@index([voterId])
}
